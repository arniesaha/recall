# Recall API Configuration

# API authentication token
API_TOKEN=your-api-token-here

# Gemini API key (required for RAG answers)
GEMINI_API_KEY=your-gemini-api-key

# LLM backend: "gemini" or "openclaw"
VECTORLESS_LLM_BACKEND=gemini

# Gemini model for RAG
VECTORLESS_GEMINI_MODEL=gemini-2.5-flash

# Vault paths (mounted in container)
VAULT_WORK_PATH=/data/obsidian/work
VAULT_PERSONAL_PATH=/data/obsidian/personal

# Logging
LOG_LEVEL=INFO
